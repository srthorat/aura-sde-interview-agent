# ── Aura SDE Interview Agent — Environment Variables ─────────────────────────
#
# Copy this file to .env and fill in your values before running locally
# or deploying to Cloud Run.
#
# All Google Cloud services are used (no Azure, no OpenAI, no Redis, no Postgres).
# --------------------------------------------------------------------------

# ── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-livekit-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Optional: prefix for room names (default: aura-s4)
LIVEKIT_ROOM_PREFIX=aura-interview

# Optional: token TTL in minutes (default: 30)
LIVEKIT_TOKEN_TTL_MINUTES=30

# ── Google Cloud ─────────────────────────────────────────────────────────────
# Project and region used for Vertex AI (Gemini Live + VertexAiSessionService)
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Service account credentials for local dev (one of the two options below)
# Option A: JSON key inline
# GOOGLE_VERTEX_CREDENTIALS={"type":"service_account",...}
# Option B: Path to JSON key file
# GOOGLE_VERTEX_CREDENTIALS_PATH=/path/to/service-account-key.json
#
# On Cloud Run: set neither — Application Default Credentials are used automatically.

# ── Gemini Live ───────────────────────────────────────────────────────────────
# Model to use for Gemini Live audio
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio

# Voice name for synthesized responses (Gemini voices: Aoede, Charon, Fenrir, Kore, Puck)
GEMINI_VOICE=Aoede

# Set to "preview" to use Google AI Studio API key instead of Vertex AI
# GEMINI_MODEL=preview
# GOOGLE_API_KEY=your_google_ai_studio_api_key

# ── Session / memory ─────────────────────────────────────────────────────────
# Handled by Vertex AI Agent Engine via VertexAiSessionService (ADK-native).
# No Redis or Postgres needed.

# ── Agent behaviour ───────────────────────────────────────────────────────────
# Optional: Override system prompt with a literal string
# BOT_SYSTEM_PROMPT=You are Aura, a helpful voice assistant.

# Seconds of silence before ending the call (default: 120)
USER_IDLE_TIMEOUT_SECS=120

# Hard maximum call duration in seconds (default: 840 = 14 min)
MAX_CALL_DURATION_SECS=840

# Seconds to wait for the first participant to join (default: 60)
CONNECTION_TIMEOUT_SECS=60

# ── Server ────────────────────────────────────────────────────────────────────
PORT=7862
